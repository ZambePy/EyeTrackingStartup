{
  "name": "irisflow",
  "private": true,
  "version": "0.1.0",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "setup": "node scripts/setup-assets.js",
    "electron:compile": "tsc -p electron/tsconfig.json",
    "electron:start": "wait-on http://localhost:5173 && npm run electron:compile && electron .",
    "electron:dev": "cross-env VITE_DEV_SERVER_URL=http://localhost:5173 concurrently -k \"npm run dev\" \"npm run electron:start\"",
    "electron:build": "npm run build && npm run electron:compile && electron-builder"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.9.1",
    "@types/node": "^22.0.0",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "wait-on": "^8.0.1"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.35",
    "@preact/signals": "^2.0.0",
    "electron-updater": "^6.3.9",
    "preact": "^10.24.0"
  }
}
